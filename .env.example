# ============================================================
# PKUSO 交响乐团管理系统 — 环境变量
# 复制此文件为 .env.local 并填入实际值
# ============================================================

# ---- Supabase (必需) ----
# 在 Supabase Dashboard → Settings → API 页面获取
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# 服务端专用:绕过 RLS,仅用于 API route(如 notify)
# 在 Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Email (必需,排练通知用; 二选一) ----
# 方式 A: SMTP(推荐,支持网易 163/QQ/企业邮箱等)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=pkuso@163.com
SMTP_PASS=<163 邮箱的 SMTP 授权码,非登录密码>
SMTP_FROM=北大交响乐团 <pkuso@163.com>
# 方式 B: Resend(回退兼容)
# 在 https://resend.com/api-keys 获取
# RESEND_API_KEY=re_...

# ---- Supabase CLI & CI (类型生成检查,CI 必需) ----
# Project reference ID: Supabase Dashboard → Settings → General → Reference ID
SUPABASE_PROJECT_REF=abcdefghijklmnopqrst
# CI gen-types-check job 需要此 token
# 在 https://supabase.com/dashboard/account/tokens 创建(选 "Generate new token")
# 同时添加到 GitHub Secrets: SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF
SUPABASE_ACCESS_TOKEN=sbp_...

# ---- 站点标识 (可选) ----
# 用于 OAuth 回调、邮件模板、SEO 等场景
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_NAME=PKUSO 乐团管理

# ---- 错误监控 (可选,后续接入) ----
# SENTRY_AUTH_TOKEN=...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ---- 运维 (可选) ----
# NEXT_PUBLIC_MAINTENANCE_MODE=false
